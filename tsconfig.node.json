{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@vben/tsconfig/node.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "noEmit": false
  },
  "include": [
    "*.config.js",
    "*.config.mjs",
    "*.config.ts",
    ".commitlintrc.js",
    "eslint.config.mjs",
    "internal/**/*.d.ts",
    "internal/**/*.mjs",
    "internal/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "stylelint.config.mjs",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
