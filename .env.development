# Development server port
VITE_PORT=5666

VITE_BASE=/

# API base URL
VITE_GLOB_API_URL=/api

# Local backend proxy targets
VITE_API_PROXY_TARGET=http://8.219.66.185:3001
VITE_UPLOADS_PROXY_TARGET=http://8.219.66.185:3001
# Keep uploads on the current origin so they also use the Vite proxy
VITE_UPLOAD_ORIGIN=

# Disable Vben mock server, use local Express backend instead
VITE_NITRO_MOCK=false

VITE_DEVTOOLS=false

VITE_INJECT_APP_LOADING=true
